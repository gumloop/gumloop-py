# Copy to `.env` (gitignored) and fill in to enable live integration tests.
# Tests in `tests/integration/` skip automatically when their required
# vars are missing, so a partial setup still runs whatever is exercisable.
#
# Get these from https://www.gumloop.com/account
GUMLOOP_API_KEY=
GUMLOOP_USER_ID=

# Optional — enables tests that actually start a flow on staging. Pick a
# flow that takes no required inputs and finishes quickly.
GUMLOOP_TEST_FLOW_ID=

# Required for the /api/v1 developer-API live tests (agents, sessions, mcp,
# skills, artifacts, teams). The dev API is rolling out to staging/local
# first, so point this at a backend that has it deployed:
#   GUMLOOP_BASE_URL=https://staging.api.gumloop.com/api/v1
#   GUMLOOP_BASE_URL=http://localhost:8080/api/v1
# Leave blank to skip the dev-API live tests.
GUMLOOP_BASE_URL=
