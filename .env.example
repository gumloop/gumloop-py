# Copy to `.env` (gitignored) and fill in to enable live integration tests.
# Tests in `tests/integration/` skip automatically when their required
# vars are missing, so a partial setup still runs whatever is exercisable.
#
# Get these from https://www.gumloop.com/account
GUMLOOP_API_KEY=
GUMLOOP_USER_ID=

# Optional — enables tests that actually start a flow. Pick a flow that
# takes no required inputs and finishes quickly.
GUMLOOP_TEST_FLOW_ID=

# Base URL for the /api/v1 developer-API live tests (agents, sessions, mcp,
# skills, artifacts, teams). Defaults to https://api.gumloop.com/api/v1
# when left unset.
GUMLOOP_BASE_URL=
