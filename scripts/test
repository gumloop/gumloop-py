#!/bin/sh
# Run the test suite. Extra args are forwarded to pytest, e.g.:
#   ./scripts/test -v
#   ./scripts/test tests/test_client.py::test_timeout_raises_when_budget_exceeded
#   ./scripts/test -k project_id
#   ./scripts/test --no-header -q
set -e
cd "$(dirname "$0")/.."

uv run --frozen pytest "$@"
